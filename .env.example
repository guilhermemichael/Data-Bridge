APP_NAME=Data-Bridge
APP_ENV=development
APP_DEBUG=true
AUTO_CREATE_TABLES=true

API_V1_PREFIX=/api/v1

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Docker Compose backend URL.
DATABASE_URL=postgresql+psycopg://databridge:databridge@db:5432/databridge
# Local backend URL when running FastAPI outside Docker:
# DATABASE_URL=postgresql+psycopg://databridge:databridge@localhost:5432/databridge
# SQLite fallback for quick development only:
# DATABASE_URL=sqlite+pysqlite:///./storage/databridge-dev.sqlite
POSTGRES_USER=databridge
POSTGRES_PASSWORD=databridge
POSTGRES_DB=databridge
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
CELERY_TASK_ALWAYS_EAGER=false

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=http://localhost:5173

UPLOAD_DIR=/app/storage/uploads
REPORT_DIR=/app/storage/reports
MAX_UPLOAD_SIZE_MB=25

LOG_LEVEL=INFO

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
